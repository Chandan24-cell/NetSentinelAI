<parameter name="content"><!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Intrusion Detection Dashboard</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #000;
            color: #fff;
            margin: 0;
            padding: 20px;
        }
        h1 {
            text-align: center;
            color: #ff4444;
        }
        #alerts-container {
            max-height: 80vh;
            overflow-y: auto;
            margin-top: 20px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            background-color: #111;
        }
        th, td {
            padding: 12px;
            text-align: left;
            border: 1px solid #333;
        }
        th {
            background-color: #222;
            position: sticky;
            top: 0;
            z-index: 10;
        }
        tr.benign {
            background-color: #112211;
        }
        tr.attack {
            background-color: #441111;
        }
        tr:hover {
            opacity: 0.8;
        }
    </style>
</head>
<body>
    <h1>🚨 Live Cyber Attack Monitoring</h1>
    <div id="alerts-container">
        <table id="alerts-table">
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Source IP</th>
                    <th>Destination IP</th>
                    <th>Protocol</th>
                    <th>Attack Type</th>
                </tr>
            </thead>
            <tbody id="alerts-body">
                <tr><td colspan="5">Loading...</td></tr>
            </tbody>
        </table>
    </div>

    <script>
        function loadAlerts() {
            fetch('http://localhost:5001/api/alerts')
                .then(response => response.json())
                .then(data => {
                    const tbody = document.getElementById('alerts-body');
                    tbody.innerHTML = '';
                    if (data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="5">No alerts</td></tr>';
                        return;
                    }
                    data.forEach(alert => {
                        const time = new Date(alert.time * 1000).toLocaleString();
                        const rowClass = alert.predicted_label !== 'BENIGN' ? 'attack' : 'benign';
                        const row = document.createElement('tr');
                        row.className = rowClass;
                        row.innerHTML = `
                            <td>${time}</td>
                            <td>${alert.src_ip || 'unknown'}</td>
                            <td>${alert.dst_ip || 'unknown'}</td>
                            <td>${alert.protocol || 'unknown'}</td>
                            <td>${alert.predicted_label}</td>
                        `;
                        tbody.appendChild(row);
                    });
                })
                .catch(error => {
                    console.error('Error fetching alerts:', error);
                    document.getElementById('alerts-body').innerHTML = '<tr><td colspan="5">Error loading alerts</td></tr>';
                });
        }

        // Load on page load
        loadAlerts();
        // Auto refresh every 3 seconds
        setInterval(loadAlerts, 3000);
    </script>
</body>
</html>
</parameter>
